    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Telegram Trigger').item.json.message.text }}",
        "options": {
          "systemMessage": "You are a search query parser. Extract LinkedIn search parameters from the user's message.\n\nAlways translate to english regardless of the input language. use your intelligence to understand the intent of the user\nExtract and return ONLY a valid JSON object with these fields (use null for missing fields):\n{\n  \"searchQuery\": \"general search term if any\",\n  \"currentJobTitles\": [\"array of job titles\"] or null,\n  \"locations\": [\"array of locations\"] or null,\n  \"currentCompanies\": [\"array of company names\"] or null,\n  \"maxItems\": number between 5-25 (default 10),\n  \"isValid\": true or false\n}\nExamples:\n\n\"Find 15 CEOs in Dubai\" -> {\"currentJobTitles\": [\"CEO\"], \"locations\": [\"Dubai\"], \"maxItems\": 15, \"isValid\": true}\n\n\"Marketing managers at Google in London\" -> {\"currentJobTitles\": [\"Marketing Manager\"], \"locations\": [\"London\"], \"currentCompanies\": [\"google\"], \"maxItems\": 10, \"isValid\": true}\n\n\"Hello\" -> {\"isValid\": false}\n\nReturn ONLY the JSON, no explanation."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        224,
        124
      ],
      "id": "3fe5fe89-40ac-4aca-97ff-b48b09d4e02a",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "model": "openai/gpt-4o-mini",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [
        296,
        348
      ],
      "id": "f4edda0a-c73a-490a-8857-a2f0ba6c3574",
      "name": "OpenRouter Chat Model",
      "credentials": {
        "openRouterApi": {
          "id": "MrGInArp43WAKaxj",
          "name": "OpenRouter account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "let responseText = '';\n\n// 1. Get the raw text from OpenAI\ntry {\n  const output = $json.output;\n  if (Array.isArray(output) && output[0]?.content?.[0]?.text) {\n    responseText = output[0].content[0].text;\n  } else {\n    responseText = $json.text || JSON.stringify($json);\n  }\n} catch (e) {\n  responseText = \"\";\n}\n\n// 2. Clean the string\nlet cleanJsonString = responseText.replace(/```json|```/g, \"\").trim();\n\n// 3. Parse and Fix Nesting\nlet parsed = {};\ntry {\n  let tempParsed = JSON.parse(cleanJsonString);\n  \n  // If the AI nested everything inside an \"output\" key, pull it out\n  if (tempParsed.output && typeof tempParsed.output === 'object') {\n    parsed = tempParsed.output;\n  } else if (typeof tempParsed.output === 'string') {\n    parsed = JSON.parse(tempParsed.output);\n  } else {\n    parsed = tempParsed;\n  }\n} catch (e) {\n  parsed = { isValid: false, error: 'Parsing failed' };\n}\n\n// 4. Get Telegram Data\nconst telegram = $('Telegram Trigger').item.json;\nconst chatId = telegram.message?.chat?.id || telegram.from?.id || '';\nconst userName = telegram.from?.first_name || 'User';\n\n// 5. Build Apify Body (Mapping fields correctly now)\nconst apifyBody = {\n  profileScraperMode: \"Full\",\n  maxItems: parsed.maxItems || 10,\n  searchQuery: parsed.searchQuery || \"\",\n  currentJobTitles: parsed.currentJobTitles || [],\n  locations: parsed.locations || [],\n  currentCompanies: parsed.currentCompanies || []\n};\n\n// 6. Return standard n8n format\nreturn [{\n  json: {\n    chat_id: chatId,\n    user_name: userName,\n    parsed_query: parsed,\n    is_valid: parsed.isValid === true || parsed.isValid === \"true\",\n    apify_body: apifyBody,\n    original_message: telegram.message?.text || \"\"\n  }\n}];"
      },
