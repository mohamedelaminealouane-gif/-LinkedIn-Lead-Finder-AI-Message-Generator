    {
      "parameters": {
        "jsCode": "// Get all items from the input\nreturn $input.all().map(item => {\n  const profile = item.json;\n\n  const firstName = profile.firstName || '';\n  const lastName = profile.lastName || '';\n  const fullName = `${firstName} ${lastName}`.trim() || 'Unknown User';\n  const email = (profile.emails && profile.emails.length > 0) ? profile.emails[0] : 'N/A';\n  const connections = profile.connectionsCount || 0;\n  \n  // 1. Extract Company Name from currentPosition array\n  const currentRole = profile.currentPosition && profile.currentPosition[0] ? profile.currentPosition[0] : {};\n  const companyName = currentRole.companyName || 'N/A';\n\n  // Extract Metadata for Telegram\n  const chatId = $('Telegram Trigger').first().json.message?.chat?.id || \"\";\n  const userName = $('Telegram Trigger').first().json.message?.from?.first_name || \"User\";\n\n  // 2. Return the formatted object for EACH item including 'company'\n  return {\n    json: {\n      chat_id: chatId,\n      user_name: userName,\n      full_name: fullName,\n      email: email,\n      connections: connections,\n      company: companyName, // New field added here\n      job_title: profile.headline || 'N/A',\n      location: profile.location?.linkedinText || 'Global',\n      linkedin_url: profile.linkedinUrl,\n      is_valid: !!profile.publicIdentifier\n    }\n  };\n});"
      },
